# Itoi runtime config template.
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; this `.env.example` should stay committed.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# Credentials applied when the `db` container is first initialized.
# They are also interpolated into DATABASE_URL below.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=itlingo

# Host port exposed for Postgres. Pick anything that's free on your machine;
# the container always listens on 5432 internally.
DB_HOST_PORT=5433

# ---------------------------------------------------------------------------
# API (Theia + Itoi extension)
# ---------------------------------------------------------------------------
# Host port for the Theia frontend (container always serves on 3000).
API_HOST_PORT=3000

# Standard Node env flag — leave as `production` unless you know why.
NODE_ENV=production

# Set to `DEV` to disable Postgres SSL, default log level to `debug`,
# and use pretty-printed colored logs. Any other value (or unset) = production mode.
ITOI_PROD=DEV

# Postgres connection string used by the Itoi backend. The default points at
# the `db` service on the compose network and matches POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB above — update all four together.
DATABASE_URL=postgres://postgres:change-me@db/itlingo

# Base URL of the ITLingo Cloud service that hands out workspace tokens and
# serves custom file lists.
ITLINGO_CLOUD_URL=http://localhost:8069/

# ---------------------------------------------------------------------------
# Secrets — MUST be replaced for any non-local deployment.
# ---------------------------------------------------------------------------
# AES-256-CBC key (exactly 32 bytes / 32 UTF-8 chars) used to decrypt the
# `iv`/`t` token pair that ITLingo Cloud appends to /createTempWorkspace.
# Must match the key used by ITLingo Cloud to encrypt those tokens.
# NOTE: Any literal `$` in this value must be doubled as `$$` because docker
# compose interprets `$VAR` and `${VAR}` inside .env values.
COM_KEY=replace-with-32-byte-aes-256-cbc-key

# Secret used by express-session to sign session cookies. Any sufficiently long
# random string is fine; rotate it to invalidate all sessions.
COOKIE_KEY=replace-with-long-random-string

# ---------------------------------------------------------------------------
# Logging (optional)
# ---------------------------------------------------------------------------
# Override the default log level: trace | debug | info | warn | error | fatal | silent
# Default is `info`, or `debug` when ITOI_PROD=DEV.
# LOG_LEVEL=debug

# Force pretty (true/1) or JSON (false/0) output. Defaults to pretty when
# ITOI_PROD=DEV and JSON otherwise.
# LOG_PRETTY=true
